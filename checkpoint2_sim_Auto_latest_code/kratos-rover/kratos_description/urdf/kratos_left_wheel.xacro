<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Define PI constant -->
  <xacro:property name="PI" value="3.14159265359"/>

  <xacro:macro name="kratos_left_wheel" params="name parent xyz rpy">

    <!-- left Wheel link -->
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <geometry>
          <mesh filename="package://kratos_description/meshes/wheel.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <geometry>
          <mesh filename="package://kratos_description/meshes/wheel.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0"/>
        <mass value="2.0"/>
        <inertia
          ixx="0.01" ixy="0" ixz="0"
          iyy="0.01" iyz="0"
          izz="0.01"/>
      </inertial>
    </link>

    <!-- left Wheel joint -->
    <joint name="${name}_joint" type="revolute">
      <parent link="${parent}"/>
      <child link="${name}"/>

      <!-- Position of wheel relative to base -->
      <origin xyz="${xyz}" rpy="${rpy}"/>

      <!-- ROTATION AXIS - Y axis for proper wheel rotation -->
      <axis xyz="0 1 0"/>

      <limit effort="5.0" velocity="10.0" lower="-1000.0" upper="1000.0"/>        
    </joint>

  </xacro:macro>

</robot>
