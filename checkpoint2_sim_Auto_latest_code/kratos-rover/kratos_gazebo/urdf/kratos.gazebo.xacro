<?xml version="1.0"?>
<robot name="kratos" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Include the base robot description -->
  <xacro:include filename="$(find kratos_description)/urdf/kratos.xacro"/>

  <!-- ========================================= -->
  <!-- GAZEBO-SPECIFIC PROPERTIES -->
  <!-- ========================================= -->
  
  <!-- Gazebo material and physics properties for base_link -->
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
    <mu1>0.5</mu1>  <!-- Friction coefficient -->
    <mu2>0.5</mu2>
    <kp>1000000.0</kp>  <!-- Contact stiffness -->
    <kd>1.0</kd>  <!-- Contact damping -->
  </gazebo>

  <!-- Gazebo properties for left wheels -->
  <gazebo reference="left_wheel_front">
    <material>Gazebo/Black</material>
    <mu1>0.0</mu1>  <!-- Higher friction for wheels -->
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
  </gazebo>

  <gazebo reference="left_wheel_middle">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
  </gazebo>

  <gazebo reference="left_wheel_rear">
    <material>Gazebo/Black</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
  </gazebo>

  <!-- Gazebo properties for right wheels -->
  <gazebo reference="right_wheel_front">
    <material>Gazebo/Black</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
  </gazebo>

  <gazebo reference="right_wheel_middle">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
  </gazebo>

  <gazebo reference="right_wheel_rear">
    <material>Gazebo/Black</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
  </gazebo>

  <!-- ========================================= -->
  <!-- GAZEBO PLUGINS -->
  <!-- ========================================= -->
  
  <!-- Differential drive plugin for robot control -->
  <!-- FIXED: Only use middle wheels (one left, one right) -->
  <gazebo>
    <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <!-- ROS 2 Configuration -->
      <ros>
        <namespace>/</namespace>
        <remapping>cmd_vel:=cmd_vel_true</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      
      <!-- Update rate in Hz -->
      <update_rate>50</update_rate>
      
      <!-- Only middle wheels are driven (one left, one right) -->
      <left_joint>left_wheel_middle_joint</left_joint>
      <right_joint>right_wheel_middle_joint</right_joint>
      
      <!-- Kinematics -->
      <wheel_separation>0.5</wheel_separation>  <!-- Distance between left and right wheels (Y-axis) -->
      <wheel_diameter>0.2</wheel_diameter>  <!-- Wheel diameter -->
      
      <!-- Limits -->
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      
      <!-- Output -->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>

  <!-- Joint state publisher plugin -->
  <gazebo>
    <plugin name="gazebo_ros_joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <update_rate>50</update_rate>
      <joint_name>left_wheel_front_joint</joint_name>
      <joint_name>left_wheel_middle_joint</joint_name>
      <joint_name>left_wheel_rear_joint</joint_name>
      <joint_name>right_wheel_front_joint</joint_name>
      <joint_name>right_wheel_middle_joint</joint_name>
      <joint_name>right_wheel_rear_joint</joint_name>
    </plugin>
  </gazebo>

  <!-- ========================================= -->
  <!-- ZED CAMERA GAZEBO SENSOR CONFIGURATION -->
  <!-- ========================================= -->
  
  <!-- ZED camera sensor configuration for Gazebo -->
  <gazebo reference="zed_left_camera_frame">
    <sensor name="zed_camera" type="depth">
      <visualize>false</visualize>
      <update_rate>10.0</update_rate>
      <camera name="zed">
        <horizontal_fov>1.91986</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.3</near>
          <far>20.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
	<ros>
          <namespace>zed</namespace>
          <remapping>zed_camera/image_raw:=zed_node/left/image_rect_color</remapping>
          <remapping>zed_camera/camera_info:=zed_node/left/camera_info</remapping>
          
          <remapping>zed_camera/depth/image_raw:=zed_node/depth/depth_registered</remapping>
          <remapping>zed_camera/points:=zed_node/point_cloud/cloud_registered</remapping>
          <remapping>zed_camera/depth/camera_info:=zed_node/depth/camera_info</remapping>
        </ros>      
	<frame_name>zed_left_camera_frame_optical</frame_name>
        <min_depth>0.3</min_depth>
        <max_depth>20.0</max_depth>
        
        <!-- Queue size and performance settings -->
        <ros>
          <qos>
            <topic name="zed_node/rgb/image_rect_color">
              <publisher>
                <reliability>best_effort</reliability>
                <durability>volatile</durability>
                <deadline>
                  <sec>0</sec>
                  <nsec>100000000</nsec>
                </deadline>
                <lifespan>
                  <sec>1</sec>
                  <nsec>0</nsec>
                </lifespan>
              </publisher>
            </topic>
            <topic name="zed_node/depth/depth_registered">
              <publisher>
                <reliability>best_effort</reliability>
                <durability>volatile</durability>
                <deadline>
                  <sec>0</sec>
                  <nsec>100000000</nsec>
                </deadline>
                <lifespan>
                  <sec>1</sec>
                  <nsec>0</nsec>
                </lifespan>
              </publisher>
            </topic>
          </qos>
        </ros>
      </plugin>
    </sensor>
  </gazebo>
  <gazebo reference="zed_left_camera_frame">
    <sensor name="zed_imu" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></z>
        </linear_acceleration>
      </imu>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <namespace>zed</namespace>
          <remapping>~/out:=zed_node/imu/data</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>
  <gazebo reference="base_link">
    <sensor name="gps_sensor" type="gps">
      <always_on>true</always_on>
      <update_rate>5.0</update_rate>
      <plugin name="gps_controller" filename="libgazebo_ros_gps_sensor.so">
        <ros>
          <namespace>/mavros/global_position</namespace>
          <remapping>~/out:=global</remapping>
        </ros>
        <output_type>sensor_msgs/NavSatFix</output_type>
      </plugin>
    </sensor>
  </gazebo>
</robot>

